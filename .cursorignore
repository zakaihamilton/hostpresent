# =============================================================================
# .cursorignore — reduce Composer indexing and token usage for hostpresent
# (Next.js 16 + React 19 WebRTC meeting app)
# =============================================================================


# -----------------------------------------------------------------------------
# Dependencies
# Installed packages; never useful for AI context (~hundreds of MB).
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions


# -----------------------------------------------------------------------------
# Build & framework output
# Generated artifacts from `next build`, `next dev`, and static export.
# .next/dev/cache/turbopack/ alone can reach 100+ MB of binary cache files.
# -----------------------------------------------------------------------------
.next/
out/
build/
dist/


# -----------------------------------------------------------------------------
# Compiler & tool caches
# SWC (Jest/Next), Turbopack, and other incremental build caches.
# -----------------------------------------------------------------------------
.swc/
.turbo/
.cache/
.parcel-cache/
.eslintcache
*.tsbuildinfo


# -----------------------------------------------------------------------------
# Test & coverage output
# Generated by Jest; not source code.
# -----------------------------------------------------------------------------
coverage/
.nyc_output/


# -----------------------------------------------------------------------------
# Deployment & hosting
# -----------------------------------------------------------------------------
.vercel/


# -----------------------------------------------------------------------------
# Lockfiles
# Large, auto-generated dependency resolution graphs (not edited by hand).
# This repo has both npm and yarn lockfiles.
# -----------------------------------------------------------------------------
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lock
bun.lockb


# -----------------------------------------------------------------------------
# Environment & secrets
# Local credentials and runtime config; also a security precaution.
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example


# -----------------------------------------------------------------------------
# Logs & debug output
# Includes Next.js dev logs (.next/dev/logs/next-development.log).
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*


# -----------------------------------------------------------------------------
# System & editor files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.pem


# -----------------------------------------------------------------------------
# Version control internals
# Git pack files and object store are large and irrelevant to coding tasks.
# -----------------------------------------------------------------------------
.git/


# -----------------------------------------------------------------------------
# Public static media assets
# Binary files that inflate token usage without aiding code understanding.
# Notable: welcome-preview.png (~2.3 MB welcome-screen preview image).
# -----------------------------------------------------------------------------
public/**/*.png
public/**/*.jpg
public/**/*.jpeg
public/**/*.gif
public/**/*.webp
public/**/*.ico
public/**/*.mp4
public/**/*.webm
public/**/*.wav
public/**/*.mp3
public/**/*.pdf

# Keep small vector/manifest assets indexable (favicon.svg, globe.svg, sw.js, etc.)
# If you add more large rasters under public/, they are already covered above.


# -----------------------------------------------------------------------------
# Source maps & minified bundles (when present outside .next/)
# -----------------------------------------------------------------------------
*.map
*.min.js
*.min.css


# -----------------------------------------------------------------------------
# Generated TypeScript declarations (Next.js scaffold)
# -----------------------------------------------------------------------------
next-env.d.ts
