{
  "name": "hostpresent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "test": "jest",
    "test:unit": "jest",
    "test:automated": "npm run test:unit -- --runInBand && npm run build && npm run test:e2e:smoke",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/welcome-smoke.spec.js --project=chromium",
    "test:e2e:webrtc": "RUN_WEBRTC_E2E=1 playwright test tests/e2e/meeting-webrtc.spec.js --project=chromium",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "next": "16.2.6",
    "peerjs": "^1.5.5",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@playwright/test": "^1.51.1",
    "babel-plugin-react-compiler": "1.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jsdom": "^29.1.1"
  }
}
